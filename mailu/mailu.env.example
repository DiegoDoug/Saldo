# ============================================================
# Mailu configuration — copy to `mailu.env` and fill in.
# `mailu.env` is gitignored; never commit real secrets.
# Regenerate a full, current file for your domain at https://setup.mailu.io.
# ============================================================

# Secret key for session/token signing. Generate 16+ random chars:
#   python -c "import secrets; print(secrets.token_hex(16))"
SECRET_KEY=change-me-16-hex-chars

# The mail domain and the public hostname of this server.
DOMAIN=example.com
HOSTNAMES=mail.example.com

# TLS strategy handled by the `front` service:
#   letsencrypt  — automatic certs (needs ports 80/443 reachable, real DNS)
#   cert         — bring your own cert in ./data/certs
#   notls        — no TLS (LOCAL DEV ONLY; never expose to the internet)
TLS_FLAVOR=letsencrypt

# First admin account, created on first boot. Log in at https://<HOSTNAMES>/admin
INITIAL_ADMIN_ACCOUNT=admin
INITIAL_ADMIN_DOMAIN=example.com
INITIAL_ADMIN_PW=change-me-strong-password

# Trim the stack: features Saldo does not need are off by default.
WEBMAIL=none
ADMIN=true
ANTIVIRUS=none
WEBDAV=none
API=false

# Storage/behaviour defaults (safe to leave as-is).
COMPRESSION=
COMPRESSION_LEVEL=
MESSAGE_SIZE_LIMIT=50000000
RECIPIENT_DELIMITER=+
DMARC_RUA=admin
DMARC_RUF=admin
WELCOME=false
