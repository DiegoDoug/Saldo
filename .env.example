# ============================================================
# Saldo — environment configuration
# Copy this file to `.env` and fill in the values.
# `.env` is gitignored; never commit real secrets.
# ============================================================

# ---- Backend ----------------------------------------------

# Path to the SQLite database file (inside the backend container this is
# the mounted named volume). Use an absolute path in Docker.
SALDO_DATABASE_URL=sqlite:///./data/saldo.db

# Secret used to sign JWTs. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# MUST be changed before exposing the app to the internet.
SALDO_JWT_SECRET=change-me-in-production

# Lifetime of an access token, in seconds (default: 7 days).
SALDO_JWT_LIFETIME_SECONDS=604800

# Comma-separated list of origins allowed to call the API (CORS).
# For local dev this is the Vite dev server.
SALDO_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ---- Email / password reset ------------------------------
# Saldo sends the password-reset link through one of two transports, chosen by
# SALDO_EMAIL_PROVIDER:
#   auto   - Resend if SALDO_RESEND_API_KEY is set, else SMTP if SALDO_SMTP_HOST
#            is set, else log-only (default)
#   resend - force the Resend HTTP API (SALDO_RESEND_API_KEY required)
#   smtp   - force SMTP (e.g. the Mailpit sink in Docker, even if a key is set)
#   log    - never send; print the email (with the working link) to the console
SALDO_EMAIL_PROVIDER=auto

# ---- Option 1: Resend (HTTP API) --------------------------
# Best when outbound SMTP ports are blocked (most clouds / home ISPs). Create a
# key at https://resend.com. SALDO_SMTP_FROM below is the "From" address and
# must be a verified sender on your Resend domain — or use onboarding@resend.dev
# (test mode: only delivers to your own Resend account email).
SALDO_RESEND_API_KEY=

# ---- Option 2: SMTP --------------------------------------
# Any mail server. Leave SALDO_SMTP_HOST BLANK for log-only. To send real mail,
# run the optional Stalwart stack (see stalwart/README.md) and fill these in.
# To TEST in Docker without DNS, start the Mailpit sink
# (`docker compose --profile dev-mail up`) and use the "Mailpit" block below.
SALDO_SMTP_HOST=
SALDO_SMTP_PORT=587
SALDO_SMTP_USER=
SALDO_SMTP_PASSWORD=
SALDO_SMTP_FROM=noreply@saldo.local
SALDO_SMTP_STARTTLS=true

# ---- Mailpit (local email testing) ------------------------
# Uncomment these to route mail into the Mailpit sink instead. `mailpit` is the
# compose service name, reachable over the internal network from the backend.
# Forcing the provider to `smtp` keeps this working even if a Resend key is set.
# SALDO_EMAIL_PROVIDER=smtp
# SALDO_SMTP_HOST=mailpit
# SALDO_SMTP_PORT=1025
# SALDO_SMTP_USER=
# SALDO_SMTP_PASSWORD=
# SALDO_SMTP_STARTTLS=false
# SALDO_SMTP_FROM=noreply@saldo.local

# Public base URL of the frontend, used to build the reset link in the email
# (e.g. https://saldo.example.com/reset-password?token=...).
SALDO_FRONTEND_BASE_URL=http://localhost:5173

# ---- Frontend ---------------------------------------------

# Base URL the frontend uses to reach the backend API.
# In Docker Compose this is proxied by nginx to the backend service.
VITE_API_BASE_URL=http://localhost:8000

# ---- Cloudflare Tunnel ------------------------------------

# Token for the `cloudflared` service. Create a tunnel in the Cloudflare
# Zero Trust dashboard and paste its token here. Leave blank for local dev
# (the cloudflared container will idle harmlessly without one).
CLOUDFLARE_TUNNEL_TOKEN=

# ---- Nightly backup (ops/backup.sh) -----------------------
# Only needed if you schedule the backup job (recommended for real data).
# Destination bucket/prefix, e.g. s3://my-bucket/saldo
# S3_DEST=
# For non-AWS S3 (Backblaze B2, MinIO, …) set the endpoint:
# AWS_ENDPOINT_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
