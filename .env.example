# ============================================================
# Saldo — environment configuration
# Copy this file to `.env` and fill in the values.
# `.env` is gitignored; never commit real secrets.
# ============================================================

# ---- Backend ----------------------------------------------

# Path to the SQLite database file (inside the backend container this is
# the mounted named volume). Use an absolute path in Docker.
SALDO_DATABASE_URL=sqlite:///./data/saldo.db

# Secret used to sign JWTs. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# MUST be changed before exposing the app to the internet.
SALDO_JWT_SECRET=change-me-in-production

# Lifetime of an access token, in seconds (default: 7 days).
SALDO_JWT_LIFETIME_SECONDS=604800

# Comma-separated list of origins allowed to call the API (CORS).
# For local dev this is the Vite dev server.
SALDO_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ---- Frontend ---------------------------------------------

# Base URL the frontend uses to reach the backend API.
# In Docker Compose this is proxied by nginx to the backend service.
VITE_API_BASE_URL=http://localhost:8000

# ---- Cloudflare Tunnel ------------------------------------

# Token for the `cloudflared` service. Create a tunnel in the Cloudflare
# Zero Trust dashboard and paste its token here. Leave blank for local dev
# (the cloudflared container will idle harmlessly without one).
CLOUDFLARE_TUNNEL_TOKEN=

# ---- Nightly backup (ops/backup.sh) -----------------------
# Only needed if you schedule the backup job (recommended for real data).
# Destination bucket/prefix, e.g. s3://my-bucket/saldo
# S3_DEST=
# For non-AWS S3 (Backblaze B2, MinIO, …) set the endpoint:
# AWS_ENDPOINT_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
